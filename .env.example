CRON_EXPRESSION=0 */2 * * *
INSTAGRAM_CRON_EXPRESSION=0 */2 * * *
YOUTUBE_CRON_EXPRESSION=0 */2 * * *
PINTEREST_CRON_EXPRESSION=0 */2 * * *
TZ=UTC
BROWSER_LOCALE=en-US
HEADLESS=false
POST_DELAY_MS=15000
POST_PUBLISH_HOLD_MS=25000
FAILURE_HOLD_MS=8000
AUTO_ADD_SOUND=false
DEFAULT_SOUND_QUERY=
RANDOM_QUEUE_ORDER=false
DEFAULT_CAPTION=
TIKTOK_UPLOAD_URL=https://www.tiktok.com/tiktokstudio/upload
INSTAGRAM_UPLOAD_URL=https://www.instagram.com/create/style/
YOUTUBE_UPLOAD_URL=https://studio.youtube.com
PINTEREST_UPLOAD_URL=https://www.pinterest.com/pin-builder/
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=3000
# DASHBOARD_ALLOW_REMOTE=false

# Video uniquifier options
# UNIQUIFY_INPUT_DIR=queue/uniquify-input
# UNIQUIFY_OUTPUT_DIR=queue/uniquify-output
# UNIQUIFY_LOGO_IMAGE=user-assets/logo.png
# UNIQUIFY_INTRO_SECONDS=1
# UNIQUIFY_END_HOLD_SECONDS=0.4

# Advanced path overrides.
# The dashboard normally uses per-account folders under queue/<account>/ and .profiles/<account>/.
# These overrides are mainly useful for CLI-only or legacy default-account setups.
# QUEUE_DIR=queue/default/tiktok/pending
# POSTED_DIR=queue/default/tiktok/posted
# FAILED_DIR=queue/default/tiktok/failed
# BROWSER_PROFILE_DIR=.profile
# INSTAGRAM_QUEUE_DIR=queue/default/instagram/pending
# INSTAGRAM_POSTED_DIR=queue/default/instagram/posted
# INSTAGRAM_FAILED_DIR=queue/default/instagram/failed
# INSTAGRAM_PROFILE_DIR=.profile-instagram
# YOUTUBE_QUEUE_DIR=queue/default/youtube/pending
# YOUTUBE_POSTED_DIR=queue/default/youtube/posted
# YOUTUBE_FAILED_DIR=queue/default/youtube/failed
# YOUTUBE_PROFILE_DIR=.profile-youtube
# PINTEREST_QUEUE_DIR=queue/default/pinterest/pending
# PINTEREST_POSTED_DIR=queue/default/pinterest/posted
# PINTEREST_FAILED_DIR=queue/default/pinterest/failed
# PINTEREST_PROFILE_DIR=.profile-pinterest

# Auto-download and auto-post pipeline
WATCH_CHANNEL=
WATCH_INTERVAL=10
WATCH_MAX_VIDEOS=5
WATCH_MIN_VIEWS=0
AUTO_POST_PLATFORMS=tiktok,instagram,youtube,pinterest

# Standalone watcher only
# ACCOUNT_ID=default
